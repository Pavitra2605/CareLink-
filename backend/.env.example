# CareLink Healthcare Backend Configuration

# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./carelink.db

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=1h

# Rate Limiting
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX_REQUESTS=10
RATE_LIMIT_CRITICAL_WINDOW_MS=60000
RATE_LIMIT_CRITICAL_MAX_REQUESTS=10
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX_REQUESTS=60

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# CORS
CORS_ORIGIN=http://localhost:3000

# Email (optional, for future notifications)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Monitoring
ENABLE_METRICS=true

# Documentation
SWAGGER_ENABLED=true
